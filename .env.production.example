NODE_ENV=production
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=madhupur-rides-api
JWT_AUDIENCE=madhupur-rides-clients
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
ADMIN_WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/madhupur_rides
POSTGRES_DB=madhupur_rides
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
OTP_PROVIDER=mock
MAPS_PROVIDER=mock
PUSH_PROVIDER=mock
FILE_STORAGE_PROVIDER=mock
MOCK_OTP_CODE=123456
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=30
